# Executable spot-checks of SPEC.md claims. Run with:  pyla tests/spec_conformance.pyla
# (also picked up by `pyla test tests/`). Every assert here quotes the spec.

# truthiness: only nil and false are falsy
assert(!!0, "0 must be truthy");
assert(!!"", "empty string must be truthy");
assert(!![], "empty array must be truthy");
assert(!nil and !false, "nil and false must be falsy");

# division rule
assert(4 / 2 == 2 and type(4 / 2) == "int", "exact int division stays int");
assert(7 / 2 == 3.5 and type(7 / 2) == "float", "inexact division is float");

# short-circuit returns the deciding operand
assert((nil or 7) == 7, "or returns right when left falsy");
assert((1 and 2) == 2, "and returns right when left truthy");

# if is an expression; blocks yield their last expression
let sign = fn(n) { if (n < 0) { -1 } else if (n == 0) { 0 } else { 1 } };
assert(sign(-5) == -1 and sign(0) == 0 and sign(9) == 1, "if-expression values");

# assignment is an expression, right-associative
let a = 0; let b = 0;
a = b = 3;
assert(a == 3 and b == 3, "chained assignment");

# pipelines
let double = fn(x) { x * 2 };
assert((5 |> double |> double) == 20, "pipeline chains left to right");
assert((5 |> fn(x, y) { x + y }(10)) == 15, "pipe injects as first argument");

# arrays: negative index, nil oob read
let arr = [1, 2, 3];
assert(arr[-1] == 3, "negative index counts from end");
assert(arr[99] == nil, "out-of-range read is nil");

# hashes: dot sugar, insertion order, missing key nil
let h = {"x": 1};
h.y = 2;
assert(h.x + h["y"] == 3, "dot access sugar");
assert(h.missing == nil, "missing hash key reads nil");
assert(join(keys(h), ",") == "x,y", "insertion order preserved");

# closures capture by reference
let counter = fn() { let n = 0; fn() { n = n + 1; n } }();
counter(); counter();
assert(counter() == 3, "closure state is shared by reference");

# stdlib pipes because collection is first parameter
let list = import("std/list");
assert((range(1, 6) |> list.map(fn(x) { x * x }) |> list.sum()) == 55, "stdlib pipes");

# strings
assert(split("a,b", ",")[1] == "b", "split");
assert(slice("language", 0, 4) == "lang", "slice");
assert(chr(ord("A")) == "A", "chr/ord roundtrip");

print("spec conformance: all assertions hold");
